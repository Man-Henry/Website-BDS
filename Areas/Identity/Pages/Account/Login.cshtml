@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-wrapper">
    <!-- Left Branding Panel -->
    <div class="auth-left">
        <div class="brand-logo">
            <i class="bi bi-buildings-fill"></i>
        </div>
        <div class="brand-title">QLPT <span>Phòng Trọ</span></div>
        <p class="brand-tagline">Hệ thống tìm kiếm và quản lý phòng trọ trực tuyến hàng đầu</p>
        <ul class="features-list">
            <li><i class="bi bi-check-circle-fill"></i> Tìm phòng nhanh chóng, minh bạch</li>
            <li><i class="bi bi-check-circle-fill"></i> Quản lý hợp đồng & hoá đơn tự động</li>
            <li><i class="bi bi-check-circle-fill"></i> Thanh toán trực tuyến an toàn</li>
            <li><i class="bi bi-check-circle-fill"></i> Hỗ trợ bảo trì 24/7</li>
        </ul>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-right">
        <div class="auth-form-box">
            <a href="/" class="btn-auth-back"><i class="bi bi-arrow-left"></i> Quay lại trang chủ</a>
            <p class="auth-greeting">Xin chào bạn 👋</p>
            <h1 class="auth-title">Đăng nhập để tiếp tục</h1>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="auth-input-group">
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="Email của bạn" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small d-block mb-2" style="margin-top:-12px;"></span>

                <div class="auth-input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Mật khẩu" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small d-block mb-3" style="margin-top:-12px;"></span>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="border-color:#C8A25C;" />
                        <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                            Nhớ tài khoản
                        </label>
                    </div>
                    <a class="auth-link small" asp-page="./ForgotPassword">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="btn-auth-primary">Đăng nhập</button>

                <div class="auth-footer-text">
                    Chưa là thành viên? <a class="auth-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký</a> tại đây
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
