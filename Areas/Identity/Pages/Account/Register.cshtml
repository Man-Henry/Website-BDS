@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-wrapper">
    <!-- Left Branding Panel -->
    <div class="auth-left">
        <div class="brand-logo">
            <i class="bi bi-buildings-fill"></i>
        </div>
        <div class="brand-title">QLPT <span>Phòng Trọ</span></div>
        <p class="brand-tagline">Tạo tài khoản để bắt đầu tìm phòng trọ hoặc quản lý khu nhà trọ của bạn</p>
        <ul class="features-list">
            <li><i class="bi bi-shield-check"></i> Bảo mật thông tin cá nhân</li>
            <li><i class="bi bi-lightning-charge"></i> Đăng ký nhanh trong 30 giây</li>
            <li><i class="bi bi-gift"></i> Hoàn toàn miễn phí</li>
        </ul>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-right">
        <div class="auth-form-box">
            <a href="/" class="btn-auth-back"><i class="bi bi-arrow-left"></i> Quay lại trang chủ</a>
            <p class="auth-greeting">Xin chào bạn 👋</p>
            <h1 class="auth-title">Đăng ký tài khoản mới</h1>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>

                <div class="auth-input-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="Email của bạn" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small d-block mb-2" style="margin-top:-12px;"></span>

                <div class="auth-input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Input.Password" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small d-block mb-2" style="margin-top:-12px;"></span>

                <div class="auth-input-group">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input asp-for="Input.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mb-3" style="margin-top:-12px;"></span>

                <div class="mb-4">
                    <label class="form-label small fw-bold" style="color:#6B7280;">Loại tài khoản</label>
                    <div class="d-flex gap-3">
                        <label class="role-option flex-fill" id="roleTenantBox">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" asp-for="Input.Role" value="Tenant" id="roleTenant" checked
                                       onchange="selectRole('roleTenantBox')">
                                <label class="form-check-label" for="roleTenant">
                                    <strong>Khách Thuê</strong>
                                    <span class="text-muted small d-block">Tìm phòng & quản lý hợp đồng</span>
                                </label>
                            </div>
                        </label>
                        <label class="role-option flex-fill" id="roleLandlordBox">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" asp-for="Input.Role" value="Admin" id="roleLandlord"
                                       onchange="selectRole('roleLandlordBox')">
                                <label class="form-check-label" for="roleLandlord">
                                    <strong>Chủ Nhà</strong>
                                    <span class="text-muted small d-block">Đăng phòng & quản lý khách</span>
                                </label>
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="Input.Role" class="text-danger small"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn-auth-primary">Đăng ký</button>

                <div class="auth-footer-text">
                    Đã có tài khoản? <a class="auth-link" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a> tại đây
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectRole(id) {
            document.querySelectorAll('.role-option').forEach(el => el.classList.remove('selected'));
            document.getElementById(id)?.classList.add('selected');
        }
        selectRole('roleTenantBox');
    </script>
}
