@model IEnumerable<Website_QLPT.Models.Room>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Trang Chủ - Tìm Phòng Trọ";
    ViewData["MetaDescription"] = "Tìm phòng trọ nhanh chóng tại TP.HCM — Hàng trăm phòng trống, giá từ 1 triệu/tháng. Lọc theo giá, diện tích, khu vực. Xem bản đồ và liên hệ chủ nhà ngay!";
    ViewData["OgTitle"] = "QLPT Phòng Trọ — Tìm Phòng Nhanh, Giá Tốt tại TP.HCM";
    
    var featured = ViewBag.FeaturedRoom as Website_QLPT.Models.Room;
    var rooms = Model.ToList();
    var gridRooms = featured != null ? rooms.Where(r => r.Id != featured.Id).Take(6).ToList() : rooms.Take(6).ToList();
}

<!-- Hero Section -->
<div class="hero-section text-center text-white py-5 mb-0" style="background: linear-gradient(160deg, #1B2A3D 0%, #263B52 60%, #2A4A6B 100%); position:relative; overflow:hidden;">
    <div style="position:absolute;width:400px;height:400px;border-radius:50%;background:rgba(200,162,92,0.05);top:-100px;right:-100px;"></div>
    <div style="position:absolute;width:250px;height:250px;border-radius:50%;background:rgba(200,162,92,0.03);bottom:-60px;left:-60px;"></div>
    <div class="container py-4 position-relative">
        <h1 class="fw-bold mb-3" style="font-size:2.4rem; letter-spacing:-0.02em;">Tìm phòng trọ và nhà ở <span style="color:#C8A25C;">phù hợp</span> với mọi người</h1>
        <p class="mb-4" style="opacity:0.6; font-size:1rem;">Hàng ngàn phòng trọ chất lượng, giá tốt đang chờ bạn khám phá</p>
        
        <!-- Search Bar -->
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <form method="get" asp-controller="Home" asp-action="Index" style="background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.12); border-radius:12px; padding:6px;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-search ms-3" style="color:rgba(255,255,255,0.4);"></i>
                        <input type="text" name="keyword" class="form-control border-0 shadow-none bg-transparent text-white" value="@ViewBag.Keyword" placeholder="Nhập tên đường, khu vực hoặc quận..." style="font-size:0.9rem;">
                        <button type="submit" class="btn px-4 fw-bold flex-shrink-0" style="background:#C8A25C; color:#1B2A3D; border-radius:8px; font-size:0.85rem;">Tìm Kiếm</button>
                    </div>
                </form>
            </div>
        </div>
        
        <!-- Quick Stats -->
        <div class="row justify-content-center mt-5">
            <div class="col-auto px-4">
                <h3 class="fw-bold mb-0" style="color:#C8A25C;">@(ViewBag.TotalRooms ?? 0)+</h3>
                <span class="small text-uppercase" style="letter-spacing:1.5px; opacity:0.5; font-size:0.7rem;">Phòng Trọ</span>
            </div>
            <div class="col-auto px-4" style="border-left:1px solid rgba(255,255,255,0.1); border-right:1px solid rgba(255,255,255,0.1);">
                <h3 class="fw-bold mb-0" style="color:#2D6A4F;">@(ViewBag.TotalAvailable ?? 0)</h3>
                <span class="small text-uppercase" style="letter-spacing:1.5px; opacity:0.5; font-size:0.7rem;">Đang Trống</span>
            </div>
            <div class="col-auto px-4">
                <h3 class="fw-bold mb-0" style="color:#C8A25C;">100%</h3>
                <span class="small text-uppercase" style="letter-spacing:1.5px; opacity:0.5; font-size:0.7rem;">Xác Thực</span>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid px-4 mt-4">
    <div class="row g-4">
        <!-- ======= LEFT SIDEBAR ======= -->
        <div class="col-lg-3 col-md-4">
            <!-- Filter Widget -->
            <div class="widget">
                <div class="widget-header">
                    <i class="bi bi-sliders"></i> Bộ Lọc Tìm Kiếm
                </div>
                <div class="widget-body">
                    <form method="get" asp-controller="Home" asp-action="Index">
                        <input type="hidden" name="keyword" value="@ViewBag.Keyword" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.72rem; letter-spacing:0.5px;">Mức Giá (VNĐ)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" min="0" step="100000" class="form-control form-control-sm" value="@ViewBag.MinPrice" placeholder="Từ" style="border-color:var(--border); background:#FAFAF8;">
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" min="0" step="100000" class="form-control form-control-sm" value="@ViewBag.MaxPrice" placeholder="Đến" style="border-color:var(--border); background:#FAFAF8;">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.72rem; letter-spacing:0.5px;">Khoảng giá nhanh</label>
                            <div class="d-flex flex-wrap gap-2">
                                @{
                                    var priceRanges = new[] {
                                        ("Dưới 2Tr", "0", "2000000"),
                                        ("2Tr - 4Tr", "2000000", "4000000"),
                                        ("4Tr - 6Tr", "4000000", "6000000"),
                                        ("Trên 6Tr", "6000000", "")
                                    };
                                }
                                @foreach (var (label, min, max) in priceRanges)
                                {
                                    bool isActive = ViewBag.MinPrice?.ToString() == min && ViewBag.MaxPrice?.ToString() == max;
                                    <a asp-controller="Home" asp-action="Index"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@min" asp-route-maxPrice="@max"
                                       class="text-decoration-none px-3 py-1"
                                       style="border-radius:6px; font-size:0.78rem; font-weight:500; border:1px solid @(isActive ? "var(--accent)" : "var(--border)"); background:@(isActive ? "var(--accent-light)" : "#FAFAF8"); color:@(isActive ? "var(--accent)" : "var(--text-muted)");">
                                        @label
                                    </a>
                                }
                            </div>
                        </div>

                        <button type="submit" class="btn w-100 fw-bold py-2 mb-2" style="background:var(--accent); color:var(--primary); border-radius:8px; font-size:0.85rem;">Áp dụng bộ lọc</button>
                        
                        @if (ViewBag.Keyword != null || ViewBag.MinPrice != null || ViewBag.MaxPrice != null)
                        {
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius:8px; font-size:0.82rem;">
                                Xoá bộ lọc
                            </a>
                        }
                    </form>
                </div>
            </div>

            <!-- Promotion Banner -->
            <div class="widget overflow-hidden" style="border:none;">
                <div class="p-4 text-white position-relative" style="background: linear-gradient(160deg, #1B2A3D, #263B52); z-index:2;">
                    <span class="badge mb-2 fw-bold" style="background:var(--accent); color:var(--primary); font-size:0.68rem;">CHO CHỦ NHÀ</span>
                    <h6 class="fw-bold mb-2" style="font-size:0.88rem;">Đăng tin cho thuê phòng miễn phí!</h6>
                    <p class="small mb-3" style="opacity:0.6; font-size:0.78rem;">Tiếp cận hàng ngàn người tìm phòng mỗi ngày.</p>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-sm w-100 fw-bold" style="background:var(--accent); color:var(--primary); border-radius:6px;">Đăng Ký Ngay</a>
                </div>
                <i class="bi bi-house-heart position-absolute" style="font-size:6rem; right:-10px; bottom:-10px; opacity:0.05; color:#fff;"></i>
            </div>
        </div>

        <!-- ======= MAIN CONTENT ======= -->
        <div class="col-lg-9 col-md-8">

            @* --- FEATURED ROOM --- *@
            @if (featured != null && (ViewBag.Keyword == null && ViewBag.MinPrice == null && ViewBag.MaxPrice == null))
            {
                var featImg = featured?.Images?.FirstOrDefault(i => i.IsThumbnail)?.ImagePath
                           ?? featured?.Images?.FirstOrDefault()?.ImagePath
                           ?? "/images/rooms/default-room.jpg";

                <div class="section-header">
                    <i class="bi bi-star-fill" style="color:var(--accent);"></i>
                    <h2>Phòng Nổi Bật</h2>
                </div>
                <div class="featured-room-card">
                    <div style="width:35%; flex-shrink:0; position:relative; overflow:hidden;">
                        <img src="@featImg" alt="Phòng @featured!.Name" style="width:100%; height:100%; object-fit:cover; min-height:220px;">
                        <div style="position:absolute; top:12px; left:12px;">
                            <span class="badge-available">Đang Trống</span>
                        </div>
                    </div>
                    <div style="flex:1; padding:24px; display:flex; flex-direction:column; justify-content:center;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h4 class="fw-bold mb-0" style="color:var(--text-dark);">Phòng @featured.Name</h4>
                            <span style="font-size:0.78rem; padding:4px 10px; border:1px solid var(--border); border-radius:6px; color:var(--text-muted);">
                                <i class="bi bi-aspect-ratio me-1"></i>@(featured.Area?.ToString("0.##") ?? "N/A") m²
                            </span>
                        </div>
                        @if (featured.Property != null)
                        {
                            <p class="small mb-1" style="color:var(--text-muted);"><i class="bi bi-geo-alt-fill me-1" style="color:#C8A25C;"></i>@featured.Property.Address</p>
                            <p class="small mb-2" style="color:var(--text-muted);"><i class="bi bi-building me-1" style="color:#C8A25C;"></i>Khu: @featured.Property.Name</p>
                        }
                        <p class="mb-3" style="color:var(--text-muted); font-size:0.85rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                            @(string.IsNullOrWhiteSpace(featured.Note) ? "Chưa có thông tin mô tả." : featured.Note)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div style="font-weight:800; font-size:1.15rem; color:var(--accent);">@featured.Price.ToString("N0") <span style="font-weight:400; font-size:0.8rem; color:var(--text-muted);">VNĐ/tháng</span></div>
                            <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@featured.Id" class="btn-view" style="width:auto; padding:8px 20px; margin:0;">Xem Chi Tiết</a>
                        </div>
                    </div>
                </div>
            }

            @* --- SEARCH RESULTS HEADER --- *@
            <div class="section-header">
                <i class="bi bi-grid-3x3-gap" style="color:var(--accent);"></i>
                <h2>@(ViewBag.Keyword != null || ViewBag.MinPrice != null ? "Kết Quả Tìm Kiếm" : "Phòng Trọ Mới Nhất")</h2>
                <span class="section-count">Hiển thị <strong>@gridRooms.Count</strong> phòng</span>
            </div>

            @* --- MAIN GRID --- *@
            @if (!gridRooms.Any())
            {
                <div class="empty-state widget py-5">
                    <i class="bi bi-search"></i>
                    <p class="fw-bold" style="color:var(--text-dark);">Không tìm thấy phòng trọ phù hợp</p>
                    <p style="font-size:0.85rem; color:var(--text-muted);">Vui lòng thử lại với từ khóa hoặc mức giá khác.</p>
                    <a asp-action="Index" class="btn px-4" style="background:var(--accent); color:var(--primary); border-radius:8px; font-weight:600;">Xóa bộ lọc</a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
                    @foreach (var room in gridRooms)
                    {
                        var imgPath = room.Images?.FirstOrDefault(i => i.IsThumbnail)?.ImagePath
                                   ?? room.Images?.FirstOrDefault()?.ImagePath
                                   ?? "/images/rooms/default-room.jpg";

                        <div class="col">
                            <div class="room-card">
                                <div style="position:relative; overflow:hidden;">
                                    <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id">
                                        <img src="@imgPath" alt="Phòng @room.Name" style="height:175px; width:100%; object-fit:cover; transition:transform 0.3s ease;">
                                    </a>
                                    @if (room.Status == Website_QLPT.Models.RoomStatus.Available)
                                    {
                                        <span class="badge-available" style="position:absolute; top:10px; right:10px;">Đang Trống</span>
                                    }
                                    else if (room.Status == Website_QLPT.Models.RoomStatus.Rented)
                                    {
                                        <span style="position:absolute; top:10px; right:10px; background:rgba(200,60,49,0.1); color:#C83C31; font-size:0.7rem; font-weight:700; padding:3px 10px; border-radius:4px;">Đã Thuê</span>
                                    }
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <div class="room-name">Phòng @room.Name</div>
                                        <span style="font-size:0.72rem; color:var(--text-muted);">@(room.Area?.ToString("0.##") ?? "N/A") m²</span>
                                    </div>
                                    @if (room.Property != null)
                                    {
                                        <div class="room-meta">
                                            <i class="bi bi-geo-alt me-1" style="color:var(--accent);"></i>@room.Property.Address
                                        </div>
                                    }
                                    <div class="d-flex justify-content-between align-items-center mt-2 pt-2" style="border-top:1px solid var(--border);">
                                        <span class="room-price">@room.Price.ToString("N0") đ</span>
                                        <span style="font-size:0.72rem; color:var(--text-muted);">@(room.Property?.Name ?? "")</span>
                                    </div>
                                    <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id" class="btn-view">
                                        <i class="bi bi-eye me-1"></i>Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- View All Button -->
                <div class="text-center mb-4">
                    <a asp-controller="Home" asp-action="AllRooms" class="btn px-5 py-2" style="background:var(--primary); color:#fff; border-radius:8px; font-weight:600; font-size:0.88rem;">
                        <i class="bi bi-grid-3x3 me-2"></i>Xem Tất Cả Phòng
                    </a>
                </div>
            }

        </div>
    </div>
</div>