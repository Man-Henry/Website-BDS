@model X.PagedList.IPagedList<Website_QLPT.Models.Room>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Tất Cả Phòng Trống";
}

<div class="container-fluid px-3 mt-2">
    <div class="row g-3">
        <!-- ======= MAIN CONTENT ======= -->
        <div class="col-lg-9 col-md-8">
            <div class="section-header">
                <i class="bi bi-grid-3x3-gap" style="color:var(--accent);"></i>
                <h2>Tất Cả Phòng Trống</h2>
                <span class="section-count">Hiện có <strong>@ViewBag.TotalCount</strong> phòng · Trang @Model.PageNumber / @Model.PageCount</span>
            </div>

            @if (Model.Any())
            {
                <!-- Horizontal listing cards -->
                @foreach (var room in Model)
                {
                    var thumb = room.Images?.FirstOrDefault(i => i.IsThumbnail)?.ImagePath
                             ?? room.Images?.FirstOrDefault()?.ImagePath
                             ?? "/images/rooms/default-room.jpg";
                    <div class="featured-room-card" style="margin-bottom:14px;">
                        <div style="width:260px; flex-shrink:0; position:relative; overflow:hidden;">
                            <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id" style="display:block; height:100%;">
                                <img src="@thumb" alt="@room.Name" style="width:100%; height:100%; min-height:180px; object-fit:cover; transition:transform 0.3s;">
                            </a>
                            @if (room.Status == Website_QLPT.Models.RoomStatus.Available)
                            {
                                <span class="badge-available" style="position:absolute; top:10px; left:10px;">Đang Trống</span>
                            }
                            else if (room.Status == Website_QLPT.Models.RoomStatus.Rented)
                            {
                                <span style="position:absolute; top:10px; left:10px; background:rgba(200,60,49,0.1); color:#C83C31; font-size:0.7rem; font-weight:700; padding:3px 10px; border-radius:4px;">Đã Thuê</span>
                            }
                        </div>
                        <div style="flex:1; padding:18px 22px; display:flex; flex-direction:column; justify-content:center;">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id" style="text-decoration:none;">
                                    <h5 class="fw-bold mb-0" style="color:var(--text-dark); font-size:1rem;">@room.Name</h5>
                                </a>
                                <span style="font-size:0.75rem; padding:3px 10px; border:1px solid var(--border); border-radius:6px; color:var(--text-muted); white-space:nowrap;">
                                    <i class="bi bi-aspect-ratio me-1"></i>@(room.Area?.ToString("0.##") ?? "N/A") m²
                                </span>
                            </div>
                            <div class="d-flex gap-3 mb-2" style="font-size:0.82rem; color:var(--text-muted);">
                                <span><i class="bi bi-geo-alt me-1" style="color:var(--accent);"></i>@(room.Property?.Address ?? "N/A")</span>
                                <span><i class="bi bi-building me-1" style="color:var(--accent);"></i>@(room.Property?.Name ?? "Khu nhà")</span>
                            </div>
                            <p style="color:var(--text-muted); font-size:0.82rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-bottom:10px;">
                                @(string.IsNullOrWhiteSpace(room.Note) ? "Chưa có thông tin mô tả." : room.Note)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div>
                                    <span class="fw-bold" style="font-size:1.1rem; color:var(--accent);">@room.Price.ToString("N0")</span>
                                    <span style="font-size:0.78rem; color:var(--text-muted);"> VNĐ/tháng</span>
                                </div>
                                <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id" class="btn-view" style="width:auto; padding:7px 18px; margin:0;">
                                    <i class="bi bi-eye me-1"></i>Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <nav aria-label="Phân trang" class="mt-3 d-flex justify-content-center">
                        <ul class="pagination pagination-sm">
                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@(Model.PageNumber - 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice"
                                       style="border-color:var(--border); color:var(--primary);">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (int i = 1; i <= Model.PageCount; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@i"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice"
                                       style="@(i == Model.PageNumber ? "background:var(--accent); border-color:var(--accent); color:var(--primary);" : "border-color:var(--border); color:var(--primary);")">@i</a>
                                </li>
                            }
                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@(Model.PageNumber + 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice"
                                       style="border-color:var(--border); color:var(--primary);">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state widget py-5">
                    <i class="bi bi-house-slash"></i>
                    <p class="fw-bold" style="color:var(--text-dark);">Không tìm thấy phòng nào phù hợp</p>
                    <p style="font-size:0.85rem; color:var(--text-muted);">Thử thay đổi bộ lọc hoặc kiểm tra lại sau.</p>
                    <a asp-controller="Home" asp-action="AllRooms" class="btn px-4" style="background:var(--accent); color:var(--primary); border-radius:8px; font-weight:600;">
                        Xem tất cả phòng
                    </a>
                </div>
            }
        </div><!-- /MAIN CONTENT -->

        <!-- ======= RIGHT SIDEBAR ======= -->
        <div class="col-lg-3 col-md-4">
            <div class="widget">
                <div class="widget-header">
                    <i class="bi bi-funnel-fill"></i> Lọc Phòng
                </div>
                <div class="widget-body">
                    <form method="get" asp-controller="Home" asp-action="AllRooms">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.7rem; letter-spacing:0.5px;">Từ khoá</label>
                            <input type="text" name="keyword" class="form-control form-control-sm"
                                   value="@ViewBag.Keyword" placeholder="Tên phòng, khu nhà..." style="border-color:var(--border); background:#FAFAF8;">
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.7rem; letter-spacing:0.5px;">Giá từ (VNĐ)</label>
                            <input type="number" name="minPrice" min="0" step="500000" class="form-control form-control-sm"
                                   value="@ViewBag.MinPrice" placeholder="VD: 1000000" style="border-color:var(--border); background:#FAFAF8;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.7rem; letter-spacing:0.5px;">Đến giá (VNĐ)</label>
                            <input type="number" name="maxPrice" min="0" step="500000" class="form-control form-control-sm"
                                   value="@ViewBag.MaxPrice" placeholder="Không giới hạn" style="border-color:var(--border); background:#FAFAF8;">
                        </div>

                        <!-- Quick Price Links -->
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase" style="color:var(--text-muted); font-size:0.7rem; letter-spacing:0.5px;">Lọc theo khoảng giá</label>
                            @{
                                var ranges = new[] {
                                    ("Dưới 1 triệu", "0", "1000000"),
                                    ("1 - 3 triệu", "1000000", "3000000"),
                                    ("3 - 5 triệu", "3000000", "5000000"),
                                    ("5 - 10 triệu", "5000000", "10000000"),
                                    ("Trên 10 triệu", "10000000", "")
                                };
                            }
                            @foreach (var (label, min, max) in ranges)
                            {
                                <a asp-controller="Home" asp-action="AllRooms"
                                   asp-route-minPrice="@min" asp-route-maxPrice="@max"
                                   class="d-block text-decoration-none py-1"
                                   style="font-size:0.82rem; color:var(--primary); border-bottom:1px solid var(--border); padding:6px 0 !important;">
                                    @label
                                </a>
                            }
                        </div>

                        <button type="submit" class="btn w-100 btn-sm fw-bold"
                                style="background:var(--accent); color:var(--primary); border-radius:8px;">
                            <i class="bi bi-search me-1"></i>Tìm kiếm
                        </button>
                        @if (ViewBag.Keyword != null || ViewBag.MinPrice != null || ViewBag.MaxPrice != null)
                        {
                            <a asp-controller="Home" asp-action="AllRooms"
                               class="btn btn-outline-secondary w-100 btn-sm mt-2" style="border-radius:8px;">
                                <i class="bi bi-x-circle me-1"></i>Xoá bộ lọc
                            </a>
                        }
                    </form>
                </div>
            </div>

            <!-- Back to Home -->
            <div class="widget">
                <div class="widget-body text-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" style="border-radius:8px; border-color:var(--border); color:var(--primary);">
                        <i class="bi bi-house-door me-1"></i>Về Trang Chủ
                    </a>
                </div>
            </div>
        </div><!-- /RIGHT SIDEBAR -->
    </div><!-- /row -->
</div>
