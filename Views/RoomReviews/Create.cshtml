@model Website_QLPT.Models.RoomReview

@{
    ViewData["Title"] = "Đánh giá phòng";
    Layout = "~/Views/Shared/_TenantLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary text-white border-0 py-3 rounded-top-4">
                <h5 class="mb-0 fw-bold"><i class="bi bi-star-fill me-2"></i>Đánh giá @ViewBag.RoomName</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="RoomId" />
                    <input type="hidden" asp-for="TenantId" />

                    <div class="mb-4 text-center">
                        <label class="form-label d-block fw-bold fs-5 mb-3">Bạn đánh giá phòng này bao nhiêu sao?</label>
                        <div class="rating-stars" id="starContainer">
                            <i class="bi bi-star text-warning fs-1 mx-1" data-value="1" style="cursor: pointer;"></i>
                            <i class="bi bi-star text-warning fs-1 mx-1" data-value="2" style="cursor: pointer;"></i>
                            <i class="bi bi-star text-warning fs-1 mx-1" data-value="3" style="cursor: pointer;"></i>
                            <i class="bi bi-star text-warning fs-1 mx-1" data-value="4" style="cursor: pointer;"></i>
                            <i class="bi bi-star text-warning fs-1 mx-1" data-value="5" style="cursor: pointer;"></i>
                        </div>
                        <input type="hidden" asp-for="Rating" id="ratingValue" value="0" />
                        <span asp-validation-for="Rating" class="text-danger d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Comment" class="form-label fw-bold">Chia sẻ trải nghiệm của bạn</label>
                        <textarea asp-for="Comment" class="form-control" rows="4" placeholder="Phòng có yên tĩnh không? Chủ nhà thế nào? Cơ sở vật chất ra sao?..."></textarea>
                        <span asp-validation-for="Comment" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill" id="submitBtn" disabled>
                            <i class="bi bi-send me-1"></i> Gửi đánh giá
                        </button>
                        <a asp-controller="TenantDashboard" asp-action="Index" class="btn btn-light rounded-pill">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            const stars = $('.rating-stars i');
            const ratingInput = $('#ratingValue');
            const submitBtn = $('#submitBtn');

            stars.on('click', function() {
                const value = $(this).data('value');
                ratingInput.val(value);
                
                // Update stars visual
                stars.removeClass('bi-star-fill').addClass('bi-star');
                for(let i = 0; i < value; i++) {
                    $(stars[i]).removeClass('bi-star').addClass('bi-star-fill');
                }

                // Enable submit
                submitBtn.prop('disabled', false);
            });

            // Hover effect
            stars.on('mouseenter', function() {
                const hoverValue = $(this).data('value');
                stars.removeClass('bi-star-fill').addClass('bi-star');
                for(let i = 0; i < hoverValue; i++) {
                    $(stars[i]).removeClass('bi-star').addClass('bi-star-fill');
                }
            });

            // Mouse leave effect - restore selected rating
            $('.rating-stars').on('mouseleave', function() {
                const selectedValue = ratingInput.val();
                stars.removeClass('bi-star-fill').addClass('bi-star');
                for(let i = 0; i < selectedValue; i++) {
                    $(stars[i]).removeClass('bi-star').addClass('bi-star-fill');
                }
            });
        });
    </script>
}
