@{
    ViewData["Title"] = "Thanh toán Demo";
    Layout = "_PublicLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header text-center bg-white py-4">
                    @if (ViewBag.Provider == "MoMo")
                    {
                        <h4 style="color: #A50064; font-weight: bold;">Cổng thanh toán MoMo (Sandbox)</h4>
                    }
                    else if (ViewBag.Provider == "PayOS")
                    {
                        <h4 style="color: #1a428a; font-weight: bold;">Cổng thanh toán VietQR (Sandbox)</h4>
                    }
                    else
                    {
                        <h4>Thanh toán (Sandbox)</h4>
                    }
                </div>
                <div class="card-body p-4 text-center">
                    <p class="mb-4 text-muted">
                        Đây là môi trường thử nghiệm (Sandbox). Trong thực tế, bạn sẽ được chuyển hướng tới trang thanh toán thật của đối tác.
                    </p>
                    
                    <h2 class="display-4 text-danger mb-4">@string.Format("{0:N0}", decimal.Parse(ViewBag.Amount ?? "0")) VNĐ</h2>
                    
                    <p>Mã giao dịch: <strong>@ViewBag.OrderId</strong></p>

                    <form asp-action="MockProcessPayment" method="post" class="mt-4">
                        <input type="hidden" name="orderId" value="@ViewBag.OrderId" />
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                        
                        <div class="d-grid gap-2">
                            <button type="submit" name="success" value="true" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Giả lập Thanh toán Thành công
                            </button>
                            <button type="submit" name="success" value="false" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Hủy giao dịch
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>