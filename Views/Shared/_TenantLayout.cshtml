<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng Khách Thuê</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 (local) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons (local) -->
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <a href="/" class="brand-icon" title="Về Trang Chủ" style="text-decoration:none;">
                <i class="bi bi-buildings"></i>
            </a>
            <div class="brand-text">
                <span class="brand-name">QLPT</span>
                <span class="brand-sub">Cổng Khách Thuê</span>
            </div>
        </div>

        <!-- User Profile -->
        <div class="sidebar-profile">
            <div class="profile-avatar tenant">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="profile-info">
                <span class="profile-name">@User.Identity?.Name</span>
                <span class="profile-role">
                    <span class="badge-role tenant">Khách thuê</span>
                </span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-label">TỔNG QUAN</span>
                <a asp-controller="TenantDashboard" asp-action="Index" class="nav-item @(IsActive("TenantDashboard", "Index"))">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">BẢO TRÌ</span>
                <a asp-controller="MaintenanceTickets" asp-action="Index" class="nav-item @(IsActive("MaintenanceTickets", "Index"))">
                    <i class="bi bi-clipboard2-check"></i>
                    <span>Phiếu Bảo Trì</span>
                </a>
                <a asp-controller="MaintenanceTickets" asp-action="Create" class="nav-item @(IsActive("MaintenanceTickets", "Create"))">
                    <i class="bi bi-plus-square"></i>
                    <span>Gửi Phiếu Mới</span>
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">TRANG CHỦ</span>
                <a href="/" class="nav-item">
                    <i class="bi bi-globe"></i>
                    <span>Về Trang Chủ</span>
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="admin-main" id="adminMain">
        <!-- Top Header -->
        <header class="admin-header">
            <button class="header-toggle" id="sidebarToggle" title="Toggle Sidebar">
                <i class="bi bi-list"></i>
            </button>

            <div class="header-breadcrumb">
                <span class="breadcrumb-text">@(ViewData["Title"] ?? "Cổng Khách Thuê")</span>
            </div>

            <div class="header-actions d-flex align-items-center">
                <div class="dropdown me-3">
                    <button class="btn btn-link text-dark position-relative p-0" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration: none;">
                        <i class="bi bi-bell fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none; font-size: 0.65rem;">
                            0
                        </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="notificationDropdown" id="notificationList" style="width: 320px; max-height: 400px; overflow-y: auto;">
                        <li class="dropdown-header d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">Thông báo</span>
                            <button class="btn btn-sm btn-link text-decoration-none p-0" id="markAllReadBtn" style="font-size: 0.8rem;">Đánh dấu đã đọc</button>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <div id="notificationItems">
                            <li><span class="dropdown-item text-muted text-center py-3">Đang tải...</span></li>
                        </div>
                    </ul>
                </div>
                <partial name="_LoginPartial" />
            </div>
        </header>

        <!-- Page Content -->
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    <!-- Nhúng Floating Chat Widget -->
    <partial name="_TenantChatWidget" />

    <!-- Global Toast Notifications -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-container-qlpt" id="globalToast">
            <div class="toast-qlpt toast-success">
                <i class="bi bi-check-circle-fill text-success"></i>
                <span>@TempData["Success"]</span>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-container-qlpt" id="globalToast">
            <div class="toast-qlpt toast-error">
                <i class="bi bi-x-circle-fill text-danger"></i>
                <span>@TempData["Error"]</span>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script src="~/js/notification.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Auto-dismiss global toast
        (function() {
            const toast = document.getElementById('globalToast');
            if (toast) {
                setTimeout(() => {
                    toast.style.transition = 'opacity 0.4s';
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 400);
                }, 3500);
            }
        })();

        // Register PWA Service Worker
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js');
            });
        }
    </script>
</body>
</html>

@functions {
    string IsActive(string controller, string? action = null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        if (action == null)
            return currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        return (currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
                currentAction.Equals(action, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    }
}
