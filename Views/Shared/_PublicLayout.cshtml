<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ===== SEO: Dynamic Meta ===== -->
    <title>@ViewData["Title"] - QLPT Phòng Trọ</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Tìm phòng trọ nhanh chóng, đa dạng khu vực, giá rẻ phù hợp sinh viên và người đi làm tại TP.HCM.")">
    <link rel="canonical" href="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />

    <!-- ===== SEO: Open Graph ===== -->
    <meta property="og:type" content="@(ViewData["OgType"] ?? "website")" />
    <meta property="og:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"] + " - QLPT Phòng Trọ")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "Tìm phòng trọ nhanh chóng, đa dạng khu vực, giá rẻ phù hợp sinh viên và người đi làm.")" />
    <meta property="og:image" content="@(ViewData["OgImage"] ?? $"{Context.Request.Scheme}://{Context.Request.Host}/images/og-default.jpg")" />
    <meta property="og:url" content="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    <meta property="og:site_name" content="QLPT Phòng Trọ" />
    <meta property="og:locale" content="vi_VN" />

    <!-- ===== SEO: Twitter Card ===== -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"])" />
    <meta name="twitter:description" content="@(ViewData["MetaDescription"] ?? "Tìm phòng trọ nhanh chóng, đa dạng khu vực.")" />
    <meta name="twitter:image" content="@(ViewData["OgImage"] ?? $"{Context.Request.Scheme}://{Context.Request.Host}/images/og-default.jpg")" />

    <!-- ===== Performance: Resource Hints ===== -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://unpkg.com" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 (local) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <!-- Bootstrap Icons (local) -->
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#1B2A3D" />

    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --primary: #1B2A3D;
            --primary-light: #263B52;
            --primary-dark: #0F1923;
            --accent: #C8A25C;
            --accent-hover: #B8923E;
            --accent-light: #F5EFE0;
            --bg: #F4F1EC;
            --card-bg: #FFFFFF;
            --text-dark: #1A1A2E;
            --text-muted: #6B7280;
            --border: #E5E0D8;
            --success: #2D6A4F;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(27,42,61,0.07);
            --shadow-lg: 0 8px 32px rgba(27,42,61,0.12);
        }
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg);
            color: var(--text-dark);
            overflow-wrap: break-word;
            -webkit-font-smoothing: antialiased;
        }
        img { max-width: 100%; height: auto; }
        a { transition: all 0.2s ease; }

        /* ===== SITE HEADER ===== */
        .site-header {
            background: var(--primary);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .site-header .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 28px;
        }
        .site-header .logo-box {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }
        .site-header .logo-icon {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, var(--accent) 0%, #D4B36A 100%);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; color: var(--primary);
        }
        .site-header .brand-name {
            color: #fff;
            font-weight: 800;
            font-size: 1.25rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
        }
        .site-header .brand-name span { color: var(--accent); }
        .site-header .brand-sub {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
            font-weight: 400;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        .site-header .header-tagline {
            color: rgba(255,255,255,0.6);
            font-size: 0.82rem;
            font-weight: 400;
        }
        .site-header .header-tagline i { color: var(--accent); margin-right: 6px; }

        /* ===== NAVBAR ===== */
        .site-nav {
            background: var(--primary-light);
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        .site-nav .navbar-nav .nav-link {
            color: rgba(255,255,255,0.7);
            font-weight: 500;
            font-size: 0.88rem;
            padding: 12px 18px;
            display: flex;
            align-items: center;
            gap: 6px;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            transition: all 0.25s ease;
            letter-spacing: 0.01em;
        }
        .site-nav .navbar-nav .nav-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.05);
        }
        .site-nav .navbar-nav .nav-link.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
            background: rgba(200,162,92,0.08);
        }
        @@media (max-width: 991.98px) {
            .site-nav .navbar-nav .nav-link {
                border-bottom: none;
                border-left: 2px solid transparent;
                margin-bottom: 0;
                padding: 10px 15px;
            }
            .site-nav .navbar-nav .nav-link.active {
                border-left-color: var(--accent);
            }
        }
        .site-nav .nav-search input {
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 7px 14px;
            font-size: 0.82rem;
            width: 240px;
            max-width: 100%;
            outline: none;
            background: rgba(255,255,255,0.08);
            color: #fff;
            transition: all 0.2s;
        }
        .site-nav .nav-search input::placeholder { color: rgba(255,255,255,0.4); }
        .site-nav .nav-search input:focus {
            background: rgba(255,255,255,0.12);
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(200,162,92,0.2);
        }
        .btn-nav-search {
            background: var(--accent);
            color: var(--primary);
            border: none;
            border-radius: 6px;
            padding: 7px 14px;
            font-weight: 600;
            font-size: 0.82rem;
            transition: all 0.2s;
        }
        .btn-nav-search:hover { background: var(--accent-hover); }
        .btn-nav-login {
            padding: 7px 18px;
            border: 1.5px solid rgba(255,255,255,0.25);
            background: transparent;
            color: rgba(255,255,255,0.85);
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .btn-nav-login:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(255,255,255,0.4); }
        .btn-nav-register {
            padding: 7px 18px;
            background: var(--accent);
            border: none;
            color: var(--primary);
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .btn-nav-register:hover { background: var(--accent-hover); color: var(--primary); }
        .btn-nav-dashboard {
            padding: 7px 18px;
            background: rgba(200,162,92,0.15);
            border: 1px solid rgba(200,162,92,0.3);
            color: var(--accent);
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .btn-nav-dashboard:hover { background: rgba(200,162,92,0.25); color: var(--accent); }

        /* ===== BREADCRUMB ===== */
        .page-breadcrumb {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            padding: 10px 0;
            font-size: 0.78rem;
            color: var(--text-muted);
        }
        .page-breadcrumb a { color: var(--primary); text-decoration: none; font-weight: 500; }
        .page-breadcrumb a:hover { color: var(--accent); }

        /* ===== SIDEBAR WIDGET ===== */
        .widget {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            margin-bottom: 16px;
            overflow: hidden;
        }
        .widget-header {
            background: var(--primary);
            color: #fff;
            padding: 11px 16px;
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: 0.01em;
        }
        .widget-header i { color: var(--accent); }
        .widget-body { padding: 16px; }

        /* ===== ROOM CARDS ===== */
        .room-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            transition: all 0.3s ease;
            height: 100%;
        }
        .room-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            border-color: var(--accent);
        }
        .room-card img { width: 100%; height: 175px; object-fit: cover; }
        .room-card .card-body { padding: 14px; }
        .room-card .room-name {
            font-weight: 700;
            font-size: 0.92rem;
            color: var(--text-dark);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .room-card .room-price {
            color: var(--accent);
            font-weight: 800;
            font-size: 1.05rem;
        }
        .room-card .room-meta {
            font-size: 0.76rem;
            color: var(--text-muted);
            margin-top: 6px;
        }
        .btn-view {
            display: block;
            text-align: center;
            padding: 8px 0;
            background: var(--primary);
            color: #fff;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            margin-top: 10px;
            transition: all 0.2s;
        }
        .btn-view:hover { background: var(--primary-light); color: var(--accent); }

        /* ===== FEATURED ROOM ===== */
        .featured-room-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 20px;
            display: flex;
            transition: all 0.3s ease;
        }
        .featured-room-card:hover {
            box-shadow: var(--shadow-lg);
            border-color: var(--accent);
        }
        .badge-featured {
            background: var(--accent);
            color: var(--primary);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 4px;
            display: inline-block;
        }
        .badge-available {
            background: rgba(45,106,79,0.1);
            color: var(--success);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 4px;
            display: inline-block;
        }

        /* ===== SECTION HEADER ===== */
        .section-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
            padding-bottom: 12px;
            border-bottom: 2px solid var(--accent);
        }
        .section-header h2 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0;
        }
        .section-header .section-count {
            margin-left: auto;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        /* ===== STAT WIDGET ===== */
        .stat-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }
        .stat-item:last-child { border-bottom: none; }
        .stat-icon {
            width: 40px; height: 40px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .stat-num { font-weight: 800; font-size: 1.2rem; line-height: 1; color: var(--accent); }
        .stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }

        /* ===== FOOTER ===== */
        .site-footer {
            background: var(--primary-dark);
            color: rgba(255,255,255,0.7);
            padding: 40px 0 16px;
            margin-top: 48px;
        }
        .site-footer h6 {
            color: var(--accent);
            font-weight: 700;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        .site-footer a {
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-size: 0.83rem;
            display: block;
            padding: 3px 0;
            transition: all 0.2s;
        }
        .site-footer a:hover { color: var(--accent); padding-left: 4px; }
        .site-footer .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.08);
            margin-top: 28px;
            padding-top: 16px;
            font-size: 0.78rem;
            text-align: center;
            color: rgba(255,255,255,0.35);
        }

        /* ===== MISC ===== */
        .empty-state { text-align: center; padding: 48px 0; color: var(--text-muted); }
        .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 12px; color: var(--accent); }
        @@media (max-width: 768px) {
            .site-header .header-tagline { display: none; }
            .featured-room-card { flex-direction: column; }
            .site-nav .nav-search input { width: 140px; }
        }
    </style>
</head>
<body>

<!-- ===== SITE HEADER ===== -->
<header class="site-header d-none d-md-block">
    <div class="container-fluid px-0">
        <div class="header-inner">
            <a class="logo-box" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <i class="bi bi-buildings-fill"></i>
                </div>
                <div>
                    <div class="brand-name">QLPT <span>Bất Động Sản</span></div>
                    <div class="brand-sub">Hệ thống tìm & quản lí phòng trọ, nhà cho thuê</div>
                </div>
            </a>
            <div class="header-tagline d-none d-xl-block">
                <i class="bi bi-shield-check"></i> Uy tín · Chất lượng · Minh bạch
            </div>
        </div>
    </div>
</header>

<!-- ===== NAVBAR ===== -->
<nav class="navbar navbar-expand-lg site-nav">
    <div class="container-fluid px-3">
        <a class="navbar-brand d-lg-none text-white fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index" style="font-size:1.1rem;">
            <div class="logo-icon" style="width:32px;height:32px;font-size:0.9rem;border-radius:6px;background:var(--accent);color:var(--primary);display:inline-flex;align-items:center;justify-content:center;">
                <i class="bi bi-buildings-fill"></i>
            </div>
            QLPT
        </a>

        <button class="navbar-toggler border-0 text-white" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
            <i class="bi bi-list fs-4"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-2 mt-lg-0">
                @{
                    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                }
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                        <i class="bi bi-house-door"></i> Trang Chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="AllRooms" class="nav-link @(currentAction == "AllRooms" ? "active" : "")">
                        <i class="bi bi-search"></i> Tìm Phòng
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Map" class="nav-link @(currentAction == "Map" ? "active" : "")">
                        <i class="bi bi-map"></i> Bản Đồ
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#site-footer" onclick="document.getElementById('site-footer').scrollIntoView({behavior:'smooth'}); return false;" class="nav-link">
                        <i class="bi bi-telephone"></i> Liên Hệ
                    </a>
                </li>
            </ul>

            <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                <form class="d-flex gap-1 align-items-center" method="get" asp-controller="Home" asp-action="Index">
                    <div class="nav-search">
                        <input type="text" name="keyword" placeholder="Tìm phòng..." value="@ViewBag.Keyword">
                    </div>
                    <button type="submit" class="btn-nav-search">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="d-flex flex-wrap gap-2 ms-lg-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <a class="btn-nav-dashboard" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Quản Trị
                            </a>
                        }
                        else
                        {
                            <a class="btn-nav-dashboard" asp-controller="TenantDashboard" asp-action="Index">
                                <i class="bi bi-person-badge me-1"></i>Trang Của Tôi
                            </a>
                        }
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-nav-login">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn-nav-login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                        <a class="btn-nav-register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
                    }
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Breadcrumb -->
<div class="page-breadcrumb d-none d-md-block">
    <div class="container-fluid px-3">
        <i class="bi bi-house-door me-1"></i>
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        @if (ViewData["Title"] != null && ViewData["Title"]?.ToString() != "Trang Chủ - Tìm Phòng Trọ")
        {
            <span class="mx-1">›</span><span>@ViewData["Title"]</span>
        }
    </div>
</div>

<!-- ===== BODY ===== -->
<main role="main" class="py-3">
    @RenderBody()
</main>

<!-- ===== FOOTER ===== -->
<footer class="site-footer" id="site-footer">
    <div class="container-fluid px-4">
        <div class="row g-4">
            <div class="col-md-4">
                <h6>QLPT Phòng Trọ</h6>
                <p style="font-size:0.83rem; line-height:1.7;">
                    Hệ thống quản lý và tìm kiếm phòng trọ trực tuyến hàng đầu.
                    Kết nối chủ nhà và người thuê nhanh chóng, tiện lợi.
                </p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" style="display:inline;padding:0;font-size:1.1rem;"><i class="bi bi-facebook"></i></a>
                    <a href="#" style="display:inline;padding:0;font-size:1.1rem;"><i class="bi bi-youtube"></i></a>
                    <a href="#" style="display:inline;padding:0;font-size:1.1rem;"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="col-md-2">
                <h6>Liên Kết</h6>
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Home" asp-action="AllRooms">Tìm phòng</a>
                <a asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                <a asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
            </div>
            <div class="col-md-3">
                <h6>Chủ Nhà</h6>
                <a asp-area="Identity" asp-page="/Account/Register">Đăng ký tài khoản</a>
                <a asp-controller="Dashboard" asp-action="Index">Quản lý khu nhà</a>
                <a asp-controller="Rooms" asp-action="Index">Quản lý phòng</a>
                <a asp-controller="Invoices" asp-action="Index">Hóa đơn</a>
            </div>
            <div class="col-md-3">
                <h6>Liên Hệ</h6>
                <p style="font-size:0.83rem; line-height:2; margin:0;">
                    <i class="bi bi-telephone me-2" style="color:var(--accent);"></i>0901 234 567<br>
                    <i class="bi bi-envelope me-2" style="color:var(--accent);"></i>contact@qlpt.vn<br>
                    <i class="bi bi-geo-alt me-2" style="color:var(--accent);"></i>TP. Hồ Chí Minh, Việt Nam
                </p>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 QLPT Phòng Trọ &mdash; All rights reserved.
        </div>
    </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => { navigator.serviceWorker.register('/sw.js'); });
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
