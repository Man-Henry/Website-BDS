@model Website_QLPT.ViewModels.QRPaymentViewModel

<div class="modal fade" id="paymentQrModal" tabindex="-1" aria-labelledby="paymentQrModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentQrModalLabel">Quét mã QR thanh toán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <div class="mb-3">
                    <p class="mb-1 text-muted">Số tiền cần thanh toán:</p>
                    <h3 class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") VNĐ</h3>
                </div>
                
                <div class="p-3 border rounded mb-3 bg-light">
                    <!-- Sử dụng VietQR API để tạo mã -->
                    <img src="https://img.vietqr.io/image/@(Model.BankId)-@(Model.AccountNo)-compact2.png?amount=@(Model.TotalAmount)&addInfo=@(Uri.EscapeDataString(Model.Content))&accountName=@(Uri.EscapeDataString(Model.AccountName))" 
                         alt="QR Code Thanh Toán" class="img-fluid" style="max-width: 250px;" />
                </div>
                
                <div class="text-start bg-light p-3 rounded" style="font-size: 14px;">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <span class="text-muted">Ngân hàng:</span>
                        <strong>@Model.BankId</strong>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <span class="text-muted">Chủ tài khoản:</span>
                        <strong>@Model.AccountName</strong>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <span class="text-muted">Số tài khoản:</span>
                        <strong>@Model.AccountNo</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Nội dung chuyển khoản:</span>
                        <strong class="text-primary">@Model.Content</strong>
                    </div>
                </div>
                
                <div class="mt-3 text-muted" style="font-size: 12px;">
                    <i class="bi bi-info-circle"></i> Vui lòng kiểm tra kỹ thông tin trước khi chuyển khoản.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
