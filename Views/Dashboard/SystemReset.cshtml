@{
    ViewData["Title"] = "Reset Hệ Thống";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
            <h5 class="mb-0">Reset Toàn Bộ Hệ Thống</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning mb-3">
                <i class="bi bi-shield-exclamation me-1"></i>
                <strong>Cảnh báo:</strong> Thao tác này sẽ <strong>xoá toàn bộ dữ liệu</strong> trong hệ thống bao gồm:
            </div>

            <ul class="list-group list-group-flush mb-3">
                <li class="list-group-item"><i class="bi bi-trash text-danger me-2"></i> Tất cả Khu nhà / Dãy trọ</li>
                <li class="list-group-item"><i class="bi bi-trash text-danger me-2"></i> Tất cả Phòng, Hình ảnh, Đánh giá</li>
                <li class="list-group-item"><i class="bi bi-trash text-danger me-2"></i> Tất cả Hợp đồng & Hóa đơn</li>
                <li class="list-group-item"><i class="bi bi-trash text-danger me-2"></i> Tất cả Khách thuê & Tài khoản người dùng</li>
                <li class="list-group-item"><i class="bi bi-trash text-danger me-2"></i> Tất cả Sự cố, Chat, Thông báo, Lịch sử</li>
                <li class="list-group-item text-success"><i class="bi bi-check-circle me-2"></i> <strong>Giữ lại:</strong> Tài khoản Admin hiện tại</li>
            </ul>

            <p class="text-muted mb-3">Sau khi reset, hệ thống sẽ tự động tạo lại dữ liệu demo.</p>

            <form asp-action="SystemResetConfirm" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="confirmation" class="form-label fw-bold">
                        Nhập <code>RESET</code> để xác nhận:
                    </label>
                    <input type="text" name="confirmation" id="confirmation"
                           class="form-control form-control-lg text-center"
                           placeholder="Nhập RESET" autocomplete="off" required />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger flex-fill">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Xác Nhận Reset
                    </button>
                    <a asp-action="Index" class="btn btn-secondary flex-fill">
                        <i class="bi bi-arrow-left me-1"></i> Huỷ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
