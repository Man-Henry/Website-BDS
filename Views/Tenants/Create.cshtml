@model Website_QLPT.Models.Tenant
@{
    ViewData["Title"] = "Thêm Khách Thuê";
}

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-person-plus me-2 text-secondary"></i>Thêm Khách Thuê Mới</h1>
    <a asp-action="Index" class="btn-qlpt btn-qlpt-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card-qlpt" style="max-width:700px;">
    <div class="card-qlpt-header bg-light d-flex justify-content-between align-items-center">
        <h6 class="mb-0 text-primary"><i class="bi bi-person-vcard me-2"></i>Điền tự động (eKYC)</h6>
        <div>
            <input type="file" id="cccdFile" class="d-none" accept="image/*" />
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('cccdFile').click()">
                <i class="bi bi-camera"></i> Chọn ảnh CCCD
            </button>
            <button type="button" class="btn btn-sm btn-primary d-none" id="btnScanCCCD">
                <span class="spinner-border spinner-border-sm d-none" id="scanSpinner" role="status" aria-hidden="true"></span>
                <i class="bi bi-magic" id="scanIcon"></i> Quét ngay
            </button>
        </div>
    </div>
    <div class="card-qlpt-body">
        <form asp-action="Create" method="post" class="form-qlpt">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-8">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-control" placeholder="VD: Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfBirth"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="NationalId"></label>
                    <input asp-for="NationalId" class="form-control" placeholder="VD: 038xxxxxx" />
                    <span asp-validation-for="NationalId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="VD: 0901234567" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="VD: nguyenvana@gmail.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
                <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle me-1"></i>Khách thuê có thể đăng nhập xem hóa đơn/bảo trì nếu họ tạo tài khoản với Email này.</small>
            </div>

            <div class="mb-3">
                <label asp-for="IdentityUserId" class="form-label">Tài khoản người thuê</label>
                <select asp-for="IdentityUserId" class="form-select" asp-items="ViewBag.IdentityUserId">
                    <option value="">-- Chưa liên kết tài khoản --</option>
                </select>
                <span asp-validation-for="IdentityUserId" class="text-danger small"></span>
                <small class="text-muted mt-1 d-block">
                    <i class="bi bi-link-45deg me-1"></i>Liên kết thủ công nếu khách thuê đã có tài khoản đăng nhập.
                </small>
            </div>

            <div class="mb-4">
                <label asp-for="HomeTown"></label>
                <textarea asp-for="HomeTown" class="form-control" rows="2" placeholder="Địa chỉ thường trú hoặc quê quán..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-qlpt btn-qlpt-primary"><i class="bi bi-check-lg"></i> Lưu khách thuê</button>
                <a asp-action="Index" class="btn-qlpt btn-qlpt-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('cccdFile').addEventListener('change', function (e) {
            if (e.target.files.length > 0) {
                document.getElementById('btnScanCCCD').classList.remove('d-none');
            }
        });

        document.getElementById('btnScanCCCD').addEventListener('click', async function () {
            var fileInput = document.getElementById('cccdFile');
            if (fileInput.files.length === 0) return;

            var formData = new FormData();
            formData.append('file', fileInput.files[0]);

            var btn = this;
            var spinner = document.getElementById('scanSpinner');
            var icon = document.getElementById('scanIcon');

            // Loading state
            btn.disabled = true;
            spinner.classList.remove('d-none');
            icon.classList.add('d-none');

            try {
                var response = await fetch('/api/ocr/scan-id', {
                    method: 'POST',
                    body: formData
                });
                var result = await response.json();

                if (result.success) {
                    if (result.fullName) document.getElementById('FullName').value = result.fullName;
                    if (result.idNumber) document.getElementById('NationalId').value = result.idNumber;
                    if (result.address) document.getElementById('HomeTown').value = result.address;
                    alert('Đã trích xuất thông tin thành công!');
                } else {
                    alert('Lỗi: ' + result.message);
                }
            } catch (error) {
                alert('Có lỗi xảy ra khi gọi dịch vụ OCR.');
            } finally {
                // Reset state
                btn.disabled = false;
                spinner.classList.add('d-none');
                icon.classList.remove('d-none');
            }
        });
    </script>
}
