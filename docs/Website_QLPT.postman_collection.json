{
  "info": {
    "name": "Website QLPT API Collection",
    "description": "Postman Collection cho hệ thống Quản Lý Phòng Trọ — 11 API Controllers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "TC-AUTH-001: Login Valid Credentials",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has JWT token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.environment.set('jwt_token', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-AUTH-002: Login Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@qlpt.dev\",\n  \"password\": \"WrongPassword\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-AUTH-003: Register New User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@test.dev\",\n  \"password\": \"Test@12345\",\n  \"fullName\": \"Test User\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-AUTH-004: Register Duplicate Email",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@qlpt.dev\",\n  \"password\": \"Test@12345\",\n  \"fullName\": \"Duplicate\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 or 409', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-AUTH-005: Protected Endpoint Without Token",
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "url": "{{base_url}}/api/v1/rooms"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Rooms",
      "item": [
        {
          "name": "TC-ROOM-001: Get All Rooms",
          "request": {
            "method": "GET",
