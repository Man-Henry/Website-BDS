            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"P.201\",\n  \"area\": 25,\n  \"price\": 4000000,\n  \"propertyId\": 1,\n  \"status\": \"Available\"\n}"
            },
            "url": "{{base_url}}/api/v1/rooms"
          },
          "event": [
