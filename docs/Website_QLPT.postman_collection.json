                ]
              }
            }
          ]
        },
        {
          "name": "TC-ROOM-003: Update Room",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"P.101 (Updated)\",\n  \"price\": 4500000\n}"
            },
            "url": "{{base_url}}/api/v1/rooms/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-ROOM-004: Delete Room (Soft Delete)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/rooms/3"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-ROOM-005: Get Room Invalid ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/rooms/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
